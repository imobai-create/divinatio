# ---- Deploy do contrato (Hardhat) ----
# Chave privada da carteira que fará o deploy na testnet (use uma carteira só de teste!)
PRIVATE_KEY=
# RPC da rede (padrões já configurados para baseSepolia e sepolia)
RPC_URL=
# Stablecoin real (ex.: USDC na Base Sepolia). Vazio = implanta o dUSD de teste com faucet
TOKEN_ADDRESS=
# Endereço da tesouraria (vazio = deployer) e caução de resolução em tokens
TREASURY_ADDRESS=
RESOLUTION_BOND=10

# ---- Backend / Railway ----
# Saída do scripts/deploy.js:
CONTRACT_ADDRESS=
# TOKEN_ADDRESS=  (o mesmo acima)
# RPC da rede onde o contrato está (ex.: https://sepolia.base.org)
# RPC_URL=
# Porta (a Railway define automaticamente)
# PORT=3001
# Opcional: ativa o keeper que executa as cópias do copy-staking
KEEPER_PRIVATE_KEY=
